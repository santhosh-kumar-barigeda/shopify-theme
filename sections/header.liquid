                </ul>
              </div>
              <div class="header__dropdown-col">
                <span class="header__dropdown-heading">Comfort Socks</span>
                <ul class="header__dropdown-list">
                  <li><a href="{{ routes.collections_url }}/womens-ankle-socks">Ankle</a></li>
                  <li><a href="{{ routes.collections_url }}/womens-crew-socks">Crew</a></li>
                  <li><a href="{{ routes.collections_url }}/womens-no-show-socks">No-Show</a></li>
                  <li><a href="{{ routes.collections_url }}/womens-over-the-calf">Over-the-Calf</a></li>
                  <li><a href="{{ routes.collections_url }}/womens-extra-roomy">Extra Roomy</a></li>
                  <li><a href="{{ routes.collections_url }}/womens-transmet">Transmet</a></li>
                  <li><a href="{{ routes.collections_url }}/womens-wool-socks">Wool</a></li>
                </ul>
              </div>
              <div class="header__dropdown-col">
                <span class="header__dropdown-heading">Orthotics</span>
                <ul class="header__dropdown-list">
                  <li><a href="{{ routes.root_url }}products/gel-insert">Gel Inserts</a></li>
                  <li><a href="{{ routes.root_url }}products/exos-insert">EXOS® Inserts</a></li>
                  <li><a href="{{ routes.root_url }}products/mysupport-custom-orthotics">mySupport™</a></li>
                </ul>
              </div>
            </div>
          </div>
        </li>

        <!-- Men's -->
