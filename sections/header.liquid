                  <li><a href="{{ routes.collections_url }}/womens-clearance" class="header__dropdown-link--accent">Clearance</a></li>
                </ul>
              </div>
              <div class="header__dropdown-col">
                <span class="header__dropdown-heading">Compression Hosiery</span>
                <ul class="header__dropdown-list">
                  <li><a href="{{ routes.collections_url }}/womens-anti-embolism">Anti-Embolism</a></li>
                  <li><a href="{{ routes.collections_url }}/womens-care-solutions">Care Solutions</a></li>
                  <li><a href="{{ routes.collections_url }}/womens-essentials">Essentials</a></li>
