                  <li><a href="{{ routes.collections_url }}/mens-sandals">Sandals</a></li>
                  <li><a href="{{ routes.collections_url }}/mens-slippers">Slippers</a></li>
                  <li><a href="{{ routes.collections_url }}/mens-specialty">Specialty</a></li>
                  <li><a href="{{ routes.collections_url }}/mens-wool">Wool</a></li>
                  <li><a href="{{ routes.collections_url }}/mens-golf">Golf</a></li>
                  <li><a href="{{ routes.collections_url }}/mens-clearance" class="header__dropdown-link--accent">Clearance</a></li>
                </ul>
              </div>
              <div class="header__dropdown-col">
                <span class="header__dropdown-heading">Compression Hosiery</span>
                <ul class="header__dropdown-list">
                  <li><a href="{{ routes.collections_url }}/mens-anti-embolism">Anti-Embolism</a></li>
                  <li><a href="{{ routes.collections_url }}/mens-care-solutions">Care Solutions</a></li>
                  <li><a href="{{ routes.collections_url }}/mens-essentials">Essentials</a></li>
                  <li><a href="{{ routes.collections_url }}/mens-everyday-style">Everyday Style</a></li>
                  <li><a href="{{ routes.collections_url }}/mens-opaque">Opaque</a></li>
                  <li><a href="{{ routes.collections_url }}/mens-therapeutic-sport">Therapeutic Sport</a></li>
                </ul>
              </div>
              <div class="header__dropdown-col">
                <span class="header__dropdown-heading">Comfort Socks</span>
                <ul class="header__dropdown-list">
                  <li><a href="{{ routes.collections_url }}/mens-ankle-socks">Ankle</a></li>
                  <li><a href="{{ routes.collections_url }}/mens-crew-socks">Crew</a></li>
