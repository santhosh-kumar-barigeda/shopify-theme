        </li>

        <!-- Compression & Socks -->
        <li class="header__nav-item">
          <a href="{{ routes.collections_url }}/compression-socks" class="header__nav-link">Compression &amp; Socks</a>
        </li>

        <!-- Accessories -->
        <li class="header__nav-item header__nav-item--has-dropdown">
          <a href="{{ routes.collections_url }}/accessories" class="header__nav-link">Accessories</a>
          <div class="header__dropdown">
            <div class="header__dropdown-inner">
              <div class="header__dropdown-col">
                <span class="header__dropdown-heading">Orthotics</span>
                <ul class="header__dropdown-list">
                  <li><a href="{{ routes.root_url }}products/gel-insert">Gel Inserts</a></li>
                  <li><a href="{{ routes.root_url }}products/exos-insert">EXOS® Inserts</a></li>
                  <li><a href="{{ routes.root_url }}products/mysupport-custom-orthotics">mySupport™</a></li>
                </ul>
              </div>
            </div>
          </div>
        </li>

        <!-- Shoe Advisor -->
        <li class="header__nav-item header__nav-item--has-dropdown">
          <a href="{{ routes.root_url }}pages/foot-indications" class="header__nav-link">Shoe Advisor</a>
          <div class="header__dropdown">
            <div class="header__dropdown-inner">
              <div class="header__dropdown-col">
                <span class="header__dropdown-heading">Find shoes for:</span>
                <ul class="header__dropdown-list">
                  <li><a href="{{ routes.root_url }}pages/foot-indications/diabetes">Diabetes</a></li>
                  <li><a href="{{ routes.root_url }}pages/foot-indications/plantar-fasciitis">Plantar Fasciitis</a></li>
                  <li><a href="{{ routes.root_url }}pages/foot-indications/stability">Stability</a></li>
                  <li><a href="{{ routes.root_url }}pages/foot-indications/bunions">Bunions</a></li>
                </ul>
              </div>
              <div class="header__dropdown-col">
                <span class="header__dropdown-heading">&nbsp;</span>
                <ul class="header__dropdown-list">
                  <li><a href="{{ routes.root_url }}pages/foot-indications/ankle-instability">Ankle Stability</a></li>
                  <li><a href="{{ routes.root_url }}pages/foot-indications/charcot">Charcot</a></li>
                  <li><a href="{{ routes.root_url }}pages/foot-indications/edema">Edema</a></li>
                  <li><a href="{{ routes.root_url }}pages/foot-indications/hammertoes">Hammertoes</a></li>
                </ul>
              </div>
              <div class="header__dropdown-col">
                <span class="header__dropdown-heading">&nbsp;</span>
                <ul class="header__dropdown-list">
                  <li><a href="{{ routes.root_url }}pages/foot-indications/high-instep">High Insteps</a></li>
                  <li><a href="{{ routes.root_url }}pages/foot-indications/internal-brace">Internal Brace</a></li>
                  <li><a href="{{ routes.root_url }}pages/foot-indications/pronation-supination">Pronation/Supination</a></li>
                </ul>
              </div>
            </div>
          </div>
        </li>

        <!-- Sale -->
        <li class="header__nav-item">
          <a href="{{ routes.collections_url }}/sale" class="header__nav-link header__nav-link--sale">Sale</a>
        </li>
      </ul>
    </nav>

    <!-- Header Actions -->
    <div class="header__actions">
      <!-- Search -->
      <form action="{{ routes.search_url }}" method="get" class="header__search-form">
        <input
          type="search"
          name="q"
          placeholder="Search"
          class="header__search-input"
          aria-label="Search"
        >
        <button type="submit" class="header__search-btn" aria-label="Search">
          <span class="material-symbols-outlined">search</span>
        </button>
      </form>

      <!-- Account -->
      <a href="{{ routes.account_url }}" class="header__action-link" aria-label="Account">
        <span class="material-symbols-outlined">person</span>
        <span class="header__action-label">Account</span>
      </a>

      <!-- Cart -->
      <a href="{{ routes.cart_url }}" class="header__action-link header__cart-link" aria-label="Cart">
        <span class="material-symbols-outlined">shopping_cart</span>
        <span class="header__action-label">My Cart</span>
        {% if cart.item_count > 0 %}
          <span class="header__cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "HEADER",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 100,
      "max": 300,
      "step": 10,
      "default": 200,
      "label": "Logo Width (px)"
    }
  ]
}
{% endschema %}
